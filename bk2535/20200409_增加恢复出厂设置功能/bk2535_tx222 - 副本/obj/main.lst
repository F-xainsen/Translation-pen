 313          void do_led(unsigned char led)
 314          {
 315   1        if (led & 1) {
 316   2          LED0_ON();
 317   2        }else {
 318   2          LED0_OFF();
 319   2        }
 320   1        if (led & 2) {
 321   2          LED1_ON();
 322   2        }else {
 323   2          LED1_OFF();
 324   2        }
 325   1      }
 326          #define led_off() do_led(0)
