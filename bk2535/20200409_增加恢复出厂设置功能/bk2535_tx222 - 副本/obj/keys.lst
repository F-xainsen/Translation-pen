1160          UINT8 I2C_RX(void)
1161          {
1162   1        BYTE i,ACC11;
1163   1        P2IN_EN &= ~0x18;        //output
1164   1        P2OUT_EN &= ~0x18;         //output
1165   1        SCL_O =0;
1166   1        delay_us(1);
1167   1        SDA_O =1;
1168   1        P2IN_EN |= 0x10;  //input
C51 COMPILER V9.01   KEYS                                                                  04/09/2020 16:23:07 PAGE 20  

1169   1        P2OUT_EN |= 0x10;
1170   1        i =8;
1171   1        do{
1172   2          ACC11 <<=1;
1173   2          SCL_O =1;
1174   2          P2IN_EN |= 0x08;  //input
1175   2          P2OUT_EN |= 0x08;  //input
1176   2          while(!SCL_I);
1177   2          P2IN_EN &= ~0x08;  //output
1178   2          P2OUT_EN &= ~0x08;  //output
1179   2          if(SDA_I) 
1180   2            ACC11 |=0x01;
1181   2          else 
1182   2            ACC11 &=0xfe;
1183   2          SCL_O =0;
1184   2        }while(--i);
1185   1        P2IN_EN &= ~0x18;        //output
1186   1        P2OUT_EN &= ~0x18;        //output
1187   1        return ACC11;
1188   1      }
