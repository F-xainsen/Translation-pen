1065   1        SCL_O =0;
1066   1        delay_us(2);
1067   1        SDA_O=1;
1068   1        delay_us(2);
1069   1        SCL_O =1;
1070   1        P2IN_EN |= 0x18;  //input
1071   1        P2OUT_EN |= 0x18;
1072   1        delay_us(1);
1073   1        if(SDA_I)
1074   1          return FALSE;
1075   1        else 
1076   1          return TRUE;
