1049   1        P2OUT_EN &= ~0x18;        //output
1050   1        do{
1051   2          SCL_O =0;
1052   2          delay_us(2);
1053   2          if(a&0x80)        
1054   2            SDA_O=1;
1055   2          else   
1056   2            SDA_O=0;
1057   2          SCL_O =1;
1058   2          P2IN_EN |= 0x08;  //input
1059   2          P2OUT_EN |= 0x08;
