1005          //-------------------------------------------------------
1006          bit SMBus_tran(BYTE p, BYTE dat)
1007          {
1008   1        P2IN_EN |= 0x18;  //input
1009   1        P2OUT_EN |= 0x18;
1010   1        if(!SDA_I || !SCL_I)
1011   1          return FAILURE;
1012   1        P2IN_EN &= ~0x18;        //output
1013   1        P2OUT_EN &= ~0x18;
1014   1        SDA_O =0;
1015   1        if(I2C_TX(0xd0)==FALSE)
1016   1        return FAILURE;
1017   1          if(I2C_TX(p)==FALSE)
1018   1        return FAILURE;
1019   1        if(I2C_TX(dat)==FALSE)
1020   1        return FAILURE; 
1021   1        P2IN_EN &= ~0x18;        //output
1022   1        P2OUT_EN &= ~0x18;       //output
1023   1        SCL_O =0;
1024   1        delay_us(2);
1025   1        SDA_O =0;
1026   1        delay_us(2);
1027   1        SCL_O =1;
1028   1        delay_us(2);
1029   1        SDA_O =1;
1030   1        return SUCCESS;
1031   1      
1032   1      }
