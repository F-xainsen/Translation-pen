 653   3          }
 654   2       }
 655   1       else
 656   1       {
 657   2         if(X>0x2000)//0x20~0x40
 658   2          {
 659   3          flag2 =~flag2;
 660   3            X =0x4000-X;
 661   3          }
 662   2       }
