 633   1       flag2 =0;
 634   1       if(Y&0x8000)
 635   1        {
 636   2         flag2=1;
 637   2         Y =-Y;
 638   2        }
 639   1       //当分量值大于0x20要做反向补偿，否则不能实现正态分布
 640   1      
 641   1       if(X&0x8000)
 642   1       {
 643   2          X=-X;
 644   2          if(X<8192)//0xe0~0x00  -8192
