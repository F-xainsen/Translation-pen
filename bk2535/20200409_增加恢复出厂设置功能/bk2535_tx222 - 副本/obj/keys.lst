 874          UINT8 _swap_(UINT8 a)
 875          {
 876   1        XDATA UINT8 ACC0;
 877   1        ACC0=a;
 878   1        ACC0 <<=4;
 879   1        ACC0=ACC0+(a>>4);
 880   1        return ACC0;
 881   1      }
 882          void tolerance_sub(short *p)
 883          {
 884   1         XDATA short a;
 885   1          a = abs(*p);
 886   1          if(a>0x10)
 887   1               a -=0x10;
 888   1          else a=0;
 889   1          if(*p & 0x8000)
 890   1               *p = (~a)+1;
 891   1          else *p = a;
 892   1      }
 893          void gyro_div(short*p, char dpi)
 894          {
 895   1      
 896   1       XDATA char i;
