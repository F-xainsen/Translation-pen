 692          UINT8 angle_get_arg(short  *angle)
 693          {
 694   1       XDATA UINT8 i,flag=0;
 695   1       XDATA UINT16 A;
 696   1       if(angle[0]&0x8000)  //这里都是按与重力线夹角计算
 697   1        {
 698   2         angle[0] =-angle[0];
 699   2         if(angle[0]>0x4000)
 700   2          {
 701   3           angle[0] =0x8000-angle[0];
 702   3           flag |=0x04;
 703   3          }
 704   2         else flag |=0x08;
 705   2        }
 706   1       else 
 707   1        {
 708   2         if(angle[0]>0x4000)
 709   2          {
 710   3           angle[0] =0x8000-angle[0];
 711   3           flag |=0x02;
 712   3          }
 713   2         else flag |=0x01;
 714   2        }
 715   1       //angle[0]=0x1000;
 716   1      
 717   1       A =arg_bit16_to_bit8(angle[0])*45;
 718   1       A =A>>6;
 719   1       i=A;
 720   1       angle[0]=angle_Tab1[45-i]; //sin@
 721   1       angle[1]=angle_Tab1[i]; //cos@
 722   1       //printf("%5d,%5d,%5d    11\r\n", angle[0],angle[1],A);
 723   1       return flag;
 724   1      }
 725          UINT16 mul13_16 (unsigned int NUM1, unsigned int NUM2)
 726          { 
 727   1         UINT16 buf;
 728   1         
 729   1         MD1 = (NUM1 & 0xff00) >> 8;
 730   1         MD0 =  NUM1 & 0x00ff;
 731   1         
 732   1         MD5 = (NUM2 & 0xff00) >> 8;
 733   1         MD4 =  NUM2 & 0x00ff;   
 734   1         
C51 COMPILER V9.01   KEYS                                                                  04/09/2020 16:23:07 PAGE 13  

 735   1         MDCTL = 0x40;
 736   1         printf("%5bx\r\n", MDCTL);
 737   1         //while ( !(MDCTL & 0x20) )     // wait done
 738   1          {
 739   2          printf("%5bx\r\n", MDCTL);
 740   2         }
 741   1         
 742   1         buf =MD3<<8;
 743   1         buf |=MD2;
 744   1         buf <<=4;
 745   1         buf |=MD1>>4;
 746   1         if(MD1&0x08)
 747   1           buf ++;
 748   1         return buf;
 749   1       }
