 902   2        *p <<=1;
 903   2        *p = -*p; 
 904   2       }
 905   1       else
 906   1       *p <<=1;          //默认放大1.5倍
 907   1       if(dpi>0)
 908   1        {
 909   2         if(dpi>5)
 910   2           dpi=5;
 911   2         for(i=0;i<dpi;i++)
 912   2           *p +=m;
 913   2        }
 914   1       else if(dpi&0x80)
 915   1        {
 916   2         dpi =-dpi;
 917   2         if(dpi>4)
 918   2           dpi=4;
 919   2         for(i=0;i<dpi;i++)
 920   2           {
C51 COMPILER V9.01   KEYS                                                                  04/09/2020 16:23:07 PAGE 16  

 921   3          if(i>1)
 922   3           *p =*p>>1;
 923   3          else
 924   3           *p=*p-m;
 925   3         }
 926   2        }
 927   1      }
