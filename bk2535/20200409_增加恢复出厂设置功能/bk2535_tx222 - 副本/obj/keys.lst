 946   3          gyro_ct[i] =0;
 947   3          gyro_coe[i] =80;//FITITER_COE_Min;
 948   3          i++;
 949   3          }while(i<2);
 950   2        }
 951   1      
 952   1      }
 953          UINT8 first_order_filter(short *now, short *old,UINT8 flag, UINT8 *coe, UINT8 *count)
 954          {
 955   1       XDATA UINT8 m;
 956   1       XDATA short data0;
 957   1      
 958   1        if(*now ==0)   //本次为0或者前后两次异号
 959   1        {
 960   2           *count =0;
 961   2         *coe =80;//FITITER_COE_Min;
 962   2         *old =0;
 963   2         return 1;
 964   2        }
 965   1       data0=*now-*old;
 966   1       m=1;
 967   1      if(data0 & 0x8000) m =0;
 968   1       if(m==flag)
 969   1         {
 970   2        *count +=data0/1024;
 971   2        *count +=1;
 972   2          if(*count>8)
 973   2            {
 974   3             *count=0;
 975   3             *coe +=8;
 976   3             if(*coe>180)//FITITER_COE_Max)
 977   3              *coe =180;//FITITER_COE_Max;
 978   3            }
 979   2         }
 980   1        else {
 981   2              *count=0;                 //方向改变 计数器清0，系数取最小
 982   2              *coe =80;//FITITER_COE_Min;
C51 COMPILER V9.01   KEYS                                                                  04/09/2020 16:23:07 PAGE 17  

 983   2             }
 984   1       // printf("%5bd, 22\r\n",*coe);
 985   1      
 986   1        data0=data0/256;
 987   1       *old +=*coe * data0;
 988   1       *now =*old/256;
 989   1       //printf("%5d, 22\r\n",*now);
 990   1        if(m) return  1;
 991   1        else  return  0; 
 992   1      }
