1089          bit SMBus_rece(BYTE a, BYTE addr,BYTE *p)
1090          {
1091   1        BYTE i=0;
1092   1         
1093   1        P2IN_EN |= 0x18;  //input
1094   1        P2OUT_EN |= 0x18;  //input
1095   1        if(!SDA_I ||!SCL_I)
1096   1          return FAILURE;
1097   1        P2IN_EN &= ~0x18;        //output
1098   1        P2OUT_EN &= ~0x18;         //output
1099   1        SDA_O =0;
1100   1        if(I2C_TX(0xd0)==FALSE)
1101   1            return FAILURE;
1102   1        if(I2C_TX(addr)==FALSE)
1103   1            return FAILURE;
1104   1        P2IN_EN &= ~0x18;        //output
1105   1        P2OUT_EN &= ~0x18;        //output
1106   1        SCL_O =0;
C51 COMPILER V9.01   KEYS                                                                  04/09/2020 16:23:07 PAGE 19  

1107   1        delay_us(2);
1108   1        SDA_O =0;
1109   1        delay_us(2);
1110   1        SCL_O =1;
1111   1        delay_us(2);
1112   1        SDA_O =1;
1113   1        delay_us(2);
1114   1        
1115   1        P2IN_EN |= 0x18;  //input
1116   1        P2OUT_EN |= 0x18;  //input
1117   1        if(!SDA_I ||!SCL_I)
1118   1          return FAILURE;
1119   1        P2IN_EN &= ~0x18;        //output
1120   1        P2OUT_EN &= ~0x18;         //output
1121   1        SDA_O =0;
1122   1        if(I2C_TX(0xd1)==FALSE)
1123   1            return FAILURE;
1124   1        for(i=0;i<a;i++)
1125   1        {
1126   2            p[i]=I2C_RX();
1127   2          if(i ==(a-1))
1128   2          {
1129   3            SDA_O =1;   //NACK
1130   3            delay_us(2);
1131   3                SCL_O =1;
1132   3          }
1133   2          else{
1134   3            SDA_O =0;
1135   3            delay_us(2);
1136   3                SCL_O =1;     //ACK
1137   3          }
1138   2        }
1139   1        P2IN_EN &= ~0x18;        //output
1140   1        P2OUT_EN &= ~0x18;        //output
1141   1        SCL_O =0;
1142   1        delay_us(2);
1143   1        SDA_O =0;
1144   1        delay_us(2);
1145   1        SCL_O =1;
1146   1        delay_us(2);
1147   1        SDA_O =1;
1148   1        return SUCCESS;
1149   1      }
