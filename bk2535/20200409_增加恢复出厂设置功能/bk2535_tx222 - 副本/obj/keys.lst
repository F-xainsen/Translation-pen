 553          short Kalman_filter_arg(short gy_ang,short acc_ang,UINT8 Hk)
 554          {
 555   1        XDATA UINT8 flag1;
 556   1       
 557   1       acc_ang -=gy_ang; //acc的矫正量，用一个系数判断矫正量的可信度    //Yk-(Xk-1 +Uk)
 558   1       if(acc_ang&0x8000)
 559   1        {
 560   2         acc_ang =-acc_ang;
 561   2           flag1 =1;
 562   2        }
 563   1       else flag1 =0;
 564   1      
 565   1       //acc_ang =mul8_16(Hk,acc_ang);//表示八位乘以16位
 566   1         acc_ang=acc_ang/(256/Hk);
 567   1       if(flag1)
 568   1        acc_ang =-acc_ang;
 569   1      
 570   1       return gy_ang +acc_ang;   //求出角度值 这里乘法是无符号乘法
 571   1      }
 572          short Kalman_axis_limit(short gy,short angle)
 573          {
 574   1      /*-------------------------------------------------------------- 
 575   1       2000°=0x80*8ms  则陀螺仪实际移动角度=2000°/(0x80*125)*x=x*1/8
 576   1       而angle关系为0x40=90°  1°=0x40/90°  带入得x*1/8*0x40/90° 
 577   1       x/11.25为对应角度值
 578   1       --------------------------------------------------------------*/
 579   1       
 580   1       gy =gy/11;
 581   1       return angle+gy;   //最佳估计值 X(k-1) +Uk 
 582   1      }
 583          UINT8 Kalman_filter_Hk(UINT16 r)
 584          {
 585   1       static XDATA UINT8 anglex_cov=10;
 586   1       static XDATA UINT8 pre_Hk=0xff;
 587   1       XDATA UINT8 Hk;
 588   1      
 589   1       anglex_cov =anglex_cov+0x05; 
 590   1       r +=anglex_cov;
 591   1       Hk =anglex_cov/arg_bit16_to_bit8(r);       //Hk
 592   1       
 593   1       anglex_cov =arg_bit16_to_bit8((256-Hk)*anglex_cov);
 594   1       if(Hk>pre_Hk)   //Hk能直接取最小值，但要线性增大
 595   1        {
 596   2         pre_Hk +=12;
 597   2         Hk =pre_Hk;
 598   2        }
 599   1       else pre_Hk=Hk;
 600   1      
 601   1        if(Hk<40)
 602   1         Hk=2;
 603   1        else Hk=40;
 604   1        
 605   1       return Hk;
 606   1      }
