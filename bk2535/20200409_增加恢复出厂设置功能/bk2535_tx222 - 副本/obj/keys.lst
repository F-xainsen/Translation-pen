 428          void gyro_read_defult(short *FIFO)
 429          {
 430   1      
 431   1       static XDATA short gyro_defult[3]={0,0,0};
 432   1       static XDATA UINT8  Len;
 433   1       XDATA UINT8 i=0;
 434   1       XDATA short a;
 435   1      
 436   1         while(i<3)
 437   1         {
 438   2          a = FIFO[i]-gyro_defult[i];
 439   2          i++;
 440   2        a =abs(a);
 441   2          if(a>0x001a)
 442   2          {
 443   3           Len =0;
 444   3           gyro_defult[0] = FIFO[0];
 445   3           gyro_defult[1] = FIFO[1];
 446   3           gyro_defult[2] = FIFO[2];
 447   3           break;                                    //跳出循环
 448   3          }
 449   2         }
 450   1         Len++;
 451   1         if(Len>0x80)
 452   1         {
 453   2        Len =0;
 454   2          for(i=0;i<3;i++)
 455   2            {
 456   3             GYRO_OFFSET[i]=(gyro_defult[i]+FIFO[i])>>1;
 457   3             FIFO[i] =0;
 458   3           //gy_off_set=1;
 459   3            }
 460   2         }
 461   1         else for(i=0; i<3; i++)
 462   1              {
 463   2               a=FIFO[i];
 464   2               FIFO[i] = FIFO[i]-GYRO_OFFSET[i];
 465   2           //a1=abs(FIFO[i]);
 466   2          //if(FIFO[i]<5)
 467   2          // FIFO[i]=0;
 468   2          //FIFO[i]=FIFO[i]/0x1a;
 469   2           if((FIFO[i]^a)&0x8000)  //方向改变
 470   2            {
 471   3             
 472   3             if(abs(a)>0x0400)
 473   3            {
 474   4             if(a&0x8000)
 475   4              FIFO[i] =0x8000;
 476   4             else FIFO[i] =0x7FFF;
 477   4            }
 478   3            }
 479   2          
 480   2              }
 481   1      }
